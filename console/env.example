# Environment variables for Agent Management Console

# OAuth Configuration
CLIENT_ID=your-client-id
BASE_URL=https://your-auth-provider.com
SIGN_IN_REDIRECT_URL=https://your-domain.com
SIGN_OUT_REDIRECT_URL=https://your-domain.com

# API Configuration
API_BASE_URL=https://your-api.com
# Gateway control plane URL (default: http://localhost:9243)
GATEWAY_CONTROL_PLANE_URL=http://localhost:9243
# Gateway version for setup commands (default: v0.9.0)
GATEWAY_VERSION=v0.9.0

# Guardrails Configuration
GUARDRAILS_CATALOG_URL=
GUARDRAILS_DEFINITION_BASE_URL=

# Authentication
DISABLE_AUTH=false

